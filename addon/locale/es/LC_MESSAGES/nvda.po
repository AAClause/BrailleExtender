"Translate the selection to Unicode braille and show it in a browseable window"
msgstr ""
"Traduce la selección a Braille Unicode y muéstrala en una ventana navegable"

#: addon/globalPlugins/brailleExtender/__init__.py:763
#: addon/globalPlugins/brailleExtender/__init__.py:779
#: addon/globalPlugins/brailleExtender/__init__.py:792
msgid "No text selection"
msgstr "Sin selección de texto"

#: addon/globalPlugins/brailleExtender/__init__.py:765
msgid "Unicode Braille conversion"
msgstr "Conversión Braille Unicode"

#: addon/globalPlugins/brailleExtender/__init__.py:770
msgid ""
"Translate the selection to dot numbers (cell descriptions) and show them in "
"a browseable window"
msgstr ""
"Traduce la selección a números de puntos (descripciones de celdas) y "
"muéstralos en una ventana navegable"

#: addon/globalPlugins/brailleExtender/__init__.py:781
msgid "Braille Unicode to cell descriptions"
msgstr "Braille Unicode a descripciones de celdas"

#: addon/globalPlugins/brailleExtender/__init__.py:785
msgid ""
"Convert selected dot-number text (for example 125-24-0) to Unicode braille "
"cells"
msgstr ""
"Convierte texto con números de puntos seleccionados (por ejemplo, 125-24-0) "
"a celdas Braille Unicode"

#: addon/globalPlugins/brailleExtender/__init__.py:795
msgid "Cell descriptions to braille Unicode"
msgstr "Descripciones de celdas en braille Unicode"

