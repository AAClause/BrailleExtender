msgid "Turn NVDA speech on or off (same as the built-in speech toggle)"
msgstr ""
"Activa o desactiva la voz de NVDA (igual que el interruptor de voz integrado)"

#: addon/globalPlugins/brailleExtender/__init__.py:715
msgid "Speech off"
msgstr "Voz apagada"

#: addon/globalPlugins/brailleExtender/__init__.py:718
msgid "Speech on"
msgstr "Voz encendida"

