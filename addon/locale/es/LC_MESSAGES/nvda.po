#: addon/globalPlugins/brailleExtender/__init__.py:656
msgid "BRF mode enabled"
msgstr "Modo BRF habilitado"

#: addon/globalPlugins/brailleExtender/__init__.py:658
msgid "BRF mode disabled"
msgstr "Modo BRF desactivado"

