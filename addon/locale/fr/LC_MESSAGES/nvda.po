msgstr "Lignes vides ignorées activé"

#: addon\globalPlugins\brailleExtender\__init__.py:1575
msgid "Skip blank lines disabled"
msgstr "Lignes vides ignorées désactivé"

#: addon\globalPlugins\brailleExtender\__init__.py:1579
